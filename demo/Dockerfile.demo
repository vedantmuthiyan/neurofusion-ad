FROM python:3.10-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn httpx structlog python-multipart && \
    pip install --no-cache-dir aiofiles

COPY src/ ./src/
COPY demo/ ./demo/

ENV PYTHONPATH=/app

EXPOSE 3000

CMD ["python", "-m", "uvicorn", "demo.backend.demo_api:app", \
     "--host", "0.0.0.0", "--port", "3000"]
